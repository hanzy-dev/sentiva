# E2E (Playwright) - example values
# Copy this file to ".env.e2e.local" and fill with your own values.

E2E_BASE_URL=http://localhost:3000

# For stable share-link e2e test, point to an EXISTING object in Supabase Storage
E2E_EXISTING_BUCKET=vault
E2E_EXISTING_OBJECT_PATH=owner-uuid/some-file.jpg
E2E_OWNER_ID=owner-uuid