# ==========================================
# Sentiva — Environment Variables Template
# ==========================================

# Public (browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (NEVER prefix with NEXT_PUBLIC)
SUPABASE_SERVICE_ROLE_KEY=

# App URL (used for redirects / absolute URLs)
# Local: http://localhost:3000
# Prod:  https://sentiva.vercel.app (or your own domain)
NEXT_PUBLIC_APP_URL=https://sentiva.vercel.app

# Cleanup job auth (required if you enable cleanup endpoint / workflow)
CRON_SECRET=

# Rate limiting (optional)
# If these are not set, limiter is disabled by design (dev/CI friendly).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=